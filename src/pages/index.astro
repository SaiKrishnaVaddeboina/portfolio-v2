---
import Base from "../layouts/Base.astro";

// ===== Content =====

const skills = [
  "Python", "SQL", "Solidity", "JavaScript", "R",
  "Hidden Markov Models", "XGBoost", "Random Forest", "K-Means", "UMAP", "SHAP",
  "Vertex AI", "AutoML", "AWS S3", "Azure", "Docker",
  "Tableau", "Power BI", "D3.js", "NVivo",
  "Truffle", "OpenZeppelin", "Web3.js", "Chainlink", "Hyperledger Fabric",
  "Vue.js", "Express.js", "MongoDB", "Node.js",
  "GENIUS Act", "MiCA", "Basel III", "FERPA/HIPAA",
];

const projects = [
  {
    num: "01",
    tag: "Featured · Industry-Sponsored",
    title: "Detecting Fare Evasion on MBTA Commuter Rail",
    summary:
      "Four-layer ML pipeline (HMM + composite anomaly score + K-means) on 2.9M activation–scan events. Surfaced 15,195 evaders the existing rule engine completely misses.",
    metrics: [
      { value: "20.5%", label: "Novelty rate" },
      { value: "9-state", label: "HMM, BIC-selected" },
      { value: "K=6", label: "Operational clusters" },
    ],
    stack: ["Python", "hmmlearn", "scikit-learn", "UMAP", "AWS S3"],
    sponsor: "Masabi × Gemsen",
    accent: "accent",
  },
  {
    num: "02",
    tag: "AI · AutoML · Credit Risk",
    title: "LoanDesk AI — Loan Decision Analyzer",
    summary:
      "AI loan pre-qualification tool deployed on Google Vertex AI. Bulk CSV processing with SHAP-style explainability and bias auditing across income, geography, age.",
    metrics: [
      { value: "0.936", label: "ROC AUC" },
      { value: "0.885", label: "F1 Score" },
      { value: "15+", label: "Applicant features" },
    ],
    stack: ["Vertex AI", "Gemini 2.5", "Python", "SHAP"],
    accent: "cobalt",
  },
  {
    num: "03",
    tag: "Data Viz · D3.js",
    title: "U.S. Cargo-Theft Surprise Index",
    summary:
      "Interactive web dashboard exploring 2024 cargo-theft surprise across all 50 states. Funnel, ranked-bar, scatter, and choropleth views. FBI NIBRS + Census data.",
    metrics: [
      { value: "50", label: "States" },
      { value: "4", label: "Visual modes" },
      { value: "FBI NIBRS", label: "+ Census" },
    ],
    stack: ["D3.js", "Python", "Pandas"],
    accent: "moss",
  },
  {
    num: "04",
    tag: "Crypto · Regulation",
    title: "Stablecoin Regulation & Architecture",
    summary:
      "Five-essay technical analysis on the CFTC tokenized-collateral decision, GENIUS Act, narrow-banking risks. Argued private permissioned blockchain best satisfies compliance.",
    metrics: [
      { value: "5", label: "Technical essays" },
      { value: "3", label: "Regulatory frameworks" },
      { value: "Permissioned", label: "Architecture" },
    ],
    stack: ["Hyperledger Fabric", "Docker", "Bloomberg"],
    accent: "accent-warm",
  },
  {
    num: "05",
    tag: "Blockchain · Full-Stack",
    title: "Property Management dApp",
    summary:
      "Full-stack decentralized real-estate dApp on Ethereum Sepolia. Role-based access control, multi-sig transfer approvals, Chainlink ETH/USD oracle. 8/8 contract tests passing.",
    metrics: [
      { value: "8/8", label: "Tests passed" },
      { value: "Multi-sig", label: "Approvals" },
      { value: "Live", label: "On Sepolia" },
    ],
    stack: ["Solidity", "Truffle", "Vue.js", "Chainlink"],
    accent: "cobalt",
  },
  {
    num: "06",
    tag: "Machine Learning",
    title: "Predicting Student Depression Risk",
    summary:
      "Random-Forest model on 27K+ student records — best performer over Logistic Regression and XGBoost. FERPA/HIPAA-compliant tiered intervention framework.",
    metrics: [
      { value: "87%", label: "Accuracy" },
      { value: "0.87", label: "F1 Score" },
      { value: "0.92", label: "ROC AUC" },
    ],
    stack: ["Python", "scikit-learn", "XGBoost"],
    accent: "moss",
  },
  {
    num: "07",
    tag: "UX Research",
    title: "Eye-Tracking & Mobile-Game Ad Study",
    summary:
      "Between-subjects ad-placement study (n=20) and within-subjects chatbot usability study (n=31). Chatbot rated significantly easier (t(29) = −2.30, p = .03).",
    metrics: [
      { value: "p=.03", label: "Significant" },
      { value: "n=51", label: "Total participants" },
      { value: "Argus", label: "ETVision" },
    ],
    stack: ["Argus", "Excel", "t-Tests"],
    accent: "accent",
  },
  {
    num: "08",
    tag: "Quant Finance",
    title: "Earnings & Stock Price Movement",
    summary:
      "Cross-sector study on 5 sectors (NVDA, GE, JPM, SPG, PFE) over a 10-year window. PEAD effects in tech, asymmetric loss-aversion in industrials.",
    metrics: [
      { value: "5", label: "Sectors" },
      { value: "10yr", label: "Window" },
      { value: "PEAD", label: "Effects found" },
    ],
    stack: ["Python", "Yahoo Finance", "OLS"],
    accent: "cobalt",
  },
];

const accentMap: Record<string, string> = {
  accent: "text-[color:var(--color-accent)]",
  cobalt: "text-[color:var(--color-cobalt)]",
  moss: "text-[color:var(--color-moss)]",
  "accent-warm": "text-[color:var(--color-accent-warm)]",
};
---

<Base>
  <!-- ============= NAV ============= -->
  <header class="fixed top-0 left-0 right-0 z-50 px-6 pt-6">
    <nav class="mx-auto max-w-6xl flex items-center justify-between
                rounded-full border border-[color:var(--color-line)]
                bg-[color:var(--color-paper)]/80 backdrop-blur-xl
                px-5 py-2.5 shadow-sm">
      <a href="#top" class="flex items-center gap-2 font-semibold tracking-tight">
        <span class="grid place-items-center w-8 h-8 rounded-full bg-[color:var(--color-ink)] text-[color:var(--color-bone)] text-xs">
          SV
        </span>
        <span class="hidden sm:inline">Sai Krishna</span>
      </a>
      <ul class="hidden md:flex items-center gap-1 text-sm">
        <li><a href="#work" class="px-3 py-1.5 rounded-full hover:bg-[color:var(--color-bone)] transition">Work</a></li>
        <li><a href="#about" class="px-3 py-1.5 rounded-full hover:bg-[color:var(--color-bone)] transition">About</a></li>
        <li><a href="#contact" class="px-3 py-1.5 rounded-full hover:bg-[color:var(--color-bone)] transition">Contact</a></li>
      </ul>
      <a href="mailto:vsaikrishna017@gmail.com"
         class="inline-flex items-center gap-1.5 px-4 py-2 text-sm
                rounded-full bg-[color:var(--color-ink)] text-[color:var(--color-bone)]
                hover:opacity-90 transition">
        Get in touch
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </nav>
  </header>

  <!-- ============= HERO BENTO ============= -->
  <main id="top" class="px-6 pt-32 pb-12">
    <section class="mx-auto max-w-6xl">

      <div class="grid grid-cols-12 gap-4 md:gap-5 auto-rows-[minmax(120px,auto)]">

        <!-- IDENTITY -->
        <div class="bento spotlight col-span-12 md:col-span-8 md:row-span-2 p-8 md:p-12 grain">
          <div class="flex flex-col h-full">
            <div class="inline-flex items-center gap-2 self-start px-3 py-1.5 rounded-full
                        bg-[color:var(--color-bone)] border border-[color:var(--color-line)]
                        text-xs font-mono">
              <span class="relative flex w-2 h-2">
                <span class="absolute inline-flex h-full w-full rounded-full bg-[color:var(--color-moss)] opacity-75 animate-ping"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[color:var(--color-moss)]"></span>
              </span>
              Available now · Open to relocate
            </div>

            <h1 class="font-serif mt-8 text-5xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tight">
              Sai Krishna<br />
              <em class="italic text-[color:var(--color-accent)]">Vaddeboina.</em>
            </h1>

            <p class="mt-6 text-lg md:text-xl text-[color:var(--color-ink-soft)] max-w-xl leading-relaxed">
              MS Financial Technology graduate from <strong class="text-[color:var(--color-ink)]">Worcester Polytechnic Institute</strong>.
              I build production-grade systems where machine learning, blockchain, and finance meet.
            </p>

            <div class="mt-auto pt-10 flex flex-wrap items-center gap-3 text-sm font-mono text-[color:var(--color-ink-dim)]">
              <span>Worcester, MA</span>
              <span class="opacity-30">·</span>
              <a href="https://github.com/SaiKrishnaVaddeboina" target="_blank" rel="noopener" class="hover:text-[color:var(--color-ink)]">GitHub</a>
              <span class="opacity-30">·</span>
              <a href="https://www.linkedin.com/in/saikrishnavaddeboina/" target="_blank" rel="noopener" class="hover:text-[color:var(--color-ink)]">LinkedIn</a>
              <span class="opacity-30">·</span>
              <a href="mailto:vsaikrishna017@gmail.com" class="hover:text-[color:var(--color-ink)]">Email</a>
            </div>
          </div>
        </div>

        <!-- PHOTO -->
        <div class="bento col-span-12 md:col-span-4 md:row-span-2 relative" style="min-height: 380px;">
          <img src="/profile.jpg" alt="Sai Krishna Vaddeboina"
               class="w-full h-full object-cover absolute inset-0" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-5 left-5 right-5 text-white">
            <p class="text-xs font-mono opacity-80">WPI School of Business · 2025</p>
            <p class="font-serif text-2xl mt-1 leading-tight">Industry-sponsored capstone, shipped.</p>
          </div>
        </div>

        <!-- GPA -->
        <div class="bento col-span-6 md:col-span-3 p-6 flex flex-col justify-between">
          <p class="text-xs font-mono text-[color:var(--color-ink-dim)] uppercase tracking-wider">GPA · WPI</p>
          <p class="font-serif text-5xl md:text-6xl text-[color:var(--color-accent)] leading-none">
            3.81<span class="text-[color:var(--color-ink-dim)] text-2xl">/4.0</span>
          </p>
        </div>

        <!-- CAPSTONE STAT -->
        <div class="bento col-span-6 md:col-span-3 p-6 flex flex-col justify-between
                    bg-[color:var(--color-ink)] text-[color:var(--color-bone)]">
          <p class="text-xs font-mono opacity-60 uppercase tracking-wider">Fraud cases found</p>
          <p class="font-serif text-5xl md:text-6xl leading-none">15,195</p>
        </div>

        <!-- CTA -->
        <div class="bento col-span-12 md:col-span-6 p-6 flex flex-wrap gap-3 items-center justify-between dots-bg">
          <div>
            <p class="text-sm text-[color:var(--color-ink-dim)]">Looking for full-time roles in</p>
            <p class="font-serif text-2xl md:text-3xl">
              Data Science · ML · FinTech · Blockchain
            </p>
          </div>
          <a href="/Sai_Krishna_Vaddeboina_Resume.pdf"
             target="_blank"
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full
                    bg-[color:var(--color-accent)] text-white text-sm font-medium
                    hover:opacity-90 transition shadow-lg">
            Download Résumé
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/>
            </svg>
          </a>
        </div>

      </div>
    </section>

    <!-- ============= MARQUEE STRIP ============= -->
    <section class="mt-16 -mx-6 overflow-hidden border-y border-[color:var(--color-line)]
                    bg-[color:var(--color-paper)] py-5">
      <div class="flex gap-3 animate-marquee whitespace-nowrap w-max">
        {[...skills, ...skills].map((skill) => (
          <span class="px-4 py-2 rounded-full border border-[color:var(--color-line)]
                       text-sm text-[color:var(--color-ink-soft)]
                       bg-[color:var(--color-bone)] flex-shrink-0">
            {skill}
          </span>
        ))}
      </div>
    </section>

    <!-- ============= SELECTED WORK ============= -->
    <section id="work" class="mx-auto max-w-6xl mt-32">
      <div class="reveal flex items-end justify-between flex-wrap gap-4 mb-10">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-ink-dim)] mb-3">
            ↳ Selected Work · 11+ projects
          </p>
          <h2 class="font-serif text-5xl md:text-6xl leading-tight">
            Real problems,<br />
            <em class="italic text-[color:var(--color-accent)]">real metrics.</em>
          </h2>
        </div>
        <p class="text-[color:var(--color-ink-soft)] max-w-md">
          Eight here, three more on request. Each one has data, methodology, and measurable outcomes — no toy datasets.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {projects.map((p, i) => (
          <article class={`bento reveal p-7 md:p-9 flex flex-col gap-5 ${i === 0 ? "md:col-span-2 grain" : ""}`}>
            <div class="flex items-center justify-between font-mono text-xs gap-3">
              <span class={`${accentMap[p.accent]} font-medium`}>{p.num} · {p.tag}</span>
              {p.sponsor && (
                <span class="px-2.5 py-1 rounded-full border border-[color:var(--color-line)] text-[color:var(--color-ink-dim)]">
                  {p.sponsor}
                </span>
              )}
            </div>

            <h3 class={`font-serif leading-tight ${i === 0 ? "text-4xl md:text-5xl" : "text-2xl md:text-3xl"}`}>
              {p.title}
            </h3>

            <p class="text-[color:var(--color-ink-soft)] leading-relaxed">
              {p.summary}
            </p>

            <div class="mt-auto space-y-4">
              <div class="grid grid-cols-3 gap-3 pt-2">
                {p.metrics.map((m) => (
                  <div class="border-l-2 border-[color:var(--color-line)] pl-3">
                    <p class={`font-serif text-xl md:text-2xl ${accentMap[p.accent]} leading-tight`}>
                      {m.value}
                    </p>
                    <p class="text-xs font-mono text-[color:var(--color-ink-dim)] mt-0.5">
                      {m.label}
                    </p>
                  </div>
                ))}
              </div>

              <div class="flex flex-wrap gap-1.5 pt-2 border-t border-[color:var(--color-line)]">
                {p.stack.map((s) => (
                  <span class="text-xs font-mono text-[color:var(--color-ink-dim)]
                               px-2 py-1 rounded-md bg-[color:var(--color-bone)]">
                    {s}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ============= ABOUT ============= -->
    <section id="about" class="mx-auto max-w-6xl mt-32">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-5">

        <div class="bento reveal col-span-12 md:col-span-8 p-8 md:p-12">
          <p class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-ink-dim)] mb-4">
            ↳ About me
          </p>
          <h2 class="font-serif text-4xl md:text-5xl leading-tight mb-8">
            From <em class="italic">commerce</em> to <em class="italic text-[color:var(--color-accent)]">code</em>.
          </h2>

          <div class="space-y-5 text-lg leading-relaxed text-[color:var(--color-ink-soft)] max-w-2xl">
            <p>
              I'm from Hyderabad, India. I did my Bachelor's in Commerce with a focus on
              chartered accountancy — three years of audit, taxation, and the kind of financial
              fluency that comes from working with real ledgers.
            </p>
            <p>
              After college I wanted to pair that finance background with technology, so I came to
              <strong class="text-[color:var(--color-ink)]">Worcester Polytechnic Institute</strong>
              for an MS in Financial Technology, which I just finished (May 2026, GPA 3.81).
            </p>
            <p>
              My capstone was with industry partners
              <strong class="text-[color:var(--color-ink)]">Masabi × Gemsen</strong>: a four-layer
              ML pipeline for detecting fare evasion on MBTA commuter rail. It surfaced 15,000+
              evaders the existing rule-based system completely missed. Real production data with
              an industry sponsor — easily the most interesting part of my program.
            </p>
            <p>
              Most of my projects sit between data analytics, machine learning, and blockchain.
              I like problems with actual data behind them and a clear question to answer.
            </p>
          </div>
        </div>

        <div class="col-span-12 md:col-span-4 grid grid-cols-2 md:grid-cols-1 gap-5">
          <div class="bento reveal p-6">
            <p class="text-xs font-mono uppercase tracking-wider text-[color:var(--color-ink-dim)]">Education</p>
            <p class="font-serif text-2xl mt-3">M.S. FinTech</p>
            <p class="text-sm text-[color:var(--color-ink-soft)] mt-1">WPI · 2024–2026</p>
            <div class="mt-4 pt-4 border-t border-[color:var(--color-line)]">
              <p class="font-serif text-2xl">B.Com (CA)</p>
              <p class="text-sm text-[color:var(--color-ink-soft)] mt-1">Noble Degree College · 2020–2024</p>
              <p class="text-xs font-mono text-[color:var(--color-ink-dim)] mt-2">CGPA 8.0/10</p>
            </div>
          </div>

          <div class="bento reveal p-6 bg-[color:var(--color-ink)] text-[color:var(--color-bone)]">
            <p class="text-xs font-mono uppercase tracking-wider opacity-60">Languages</p>
            <ul class="mt-3 space-y-1.5 font-serif text-xl">
              <li>English</li>
              <li>Telugu</li>
              <li>Hindi</li>
            </ul>
          </div>
        </div>

      </div>
    </section>

    <!-- ============= CONTACT ============= -->
    <section id="contact" class="mx-auto max-w-6xl mt-32 mb-20">
      <div class="bento reveal spotlight relative p-10 md:p-20 grain text-center">

        <p class="font-mono text-xs uppercase tracking-widest text-[color:var(--color-ink-dim)] mb-5">
          ↳ Let's talk
        </p>

        <h2 class="font-serif text-5xl md:text-7xl leading-[0.95]">
          Hiring? Building?<br />
          <em class="italic text-[color:var(--color-accent)]">Or just curious.</em>
        </h2>

        <p class="text-lg text-[color:var(--color-ink-soft)] mt-8 max-w-xl mx-auto">
          I'm actively looking for full-time roles starting now.
          Data science, ML engineering, FinTech product, quantitative research, blockchain — all open.
        </p>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
          <a href="mailto:vsaikrishna017@gmail.com"
             class="inline-flex items-center gap-2 px-6 py-3 rounded-full
                    bg-[color:var(--color-ink)] text-[color:var(--color-bone)]
                    hover:opacity-90 transition shadow-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Email me
          </a>
          <a href="https://www.linkedin.com/in/saikrishnavaddeboina/"
             target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 px-6 py-3 rounded-full
                    border border-[color:var(--color-line)] bg-[color:var(--color-paper)]
                    hover:border-[color:var(--color-ink)] transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/>
            </svg>
            LinkedIn
          </a>
          <a href="https://github.com/SaiKrishnaVaddeboina"
             target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 px-6 py-3 rounded-full
                    border border-[color:var(--color-line)] bg-[color:var(--color-paper)]
                    hover:border-[color:var(--color-ink)] transition">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.69.08-.69 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 015.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- ============= FOOTER ============= -->
  <footer class="mx-auto max-w-6xl px-6 pb-10 pt-6 border-t border-[color:var(--color-line)]
                 mt-10 flex flex-wrap items-center justify-between gap-3 text-xs font-mono text-[color:var(--color-ink-dim)]">
    <p>© 2026 Sai Krishna Vaddeboina — Built with Astro + Tailwind, deployed on Vercel.</p>
    <p>v2 · Bento Edition</p>
  </footer>
</Base>
