---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Sai Krishna Vaddeboina — FinTech & Finance · MS WPI '26",
  description = "MS Financial Technology graduate from Worcester Polytechnic Institute (GPA 3.81). Open to full-time + internship roles in FinTech, finance, investment banking, quantitative research, ML, and blockchain.",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://saikrishnavaddeboina.vercel.app");
const absoluteOgImage = new URL(ogImage, Astro.site ?? "https://saikrishnavaddeboina.vercel.app").toString();

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Sai Krishna Vaddeboina",
  givenName: "Sai Krishna",
  familyName: "Vaddeboina",
  jobTitle: "MS Financial Technology Graduate",
  description: "FinTech & finance professional with an MS from Worcester Polytechnic Institute and a commerce + chartered-accountancy background.",
  email: "vsaikrishna017@gmail.com",
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "Worcester Polytechnic Institute", sameAs: "https://www.wpi.edu/" },
    { "@type": "CollegeOrUniversity", name: "Noble Degree & PG College, Hyderabad" },
  ],
  knowsAbout: [
    "FinTech", "Investment Banking", "Quantitative Research", "Asset Management",
    "Machine Learning", "Hidden Markov Models", "Blockchain", "Solidity",
    "Financial Analytics", "Credit Risk", "Fraud Detection",
    "Tableau", "Power BI", "Python", "SQL",
  ],
  url: "https://saikrishnavaddeboina.vercel.app",
  sameAs: [
    "https://www.linkedin.com/in/saikrishnavaddeboina/",
    "https://github.com/SaiKrishnaVaddeboina",
  ],
  address: { "@type": "PostalAddress", addressLocality: "Worcester", addressRegion: "MA", addressCountry: "US" },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Sai Krishna Vaddeboina" />
    <meta name="keywords" content="Sai Krishna Vaddeboina, FinTech, Finance, Investment Banking, Asset Management, Quantitative Research, Machine Learning, Blockchain, MS FinTech, WPI, Worcester Polytechnic Institute, Hidden Markov Models, Credit Risk, Stablecoin, Python, Tableau" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Sai Krishna Vaddeboina — FinTech & Finance · MS WPI '26" />
    <meta property="og:site_name" content="Sai Krishna Vaddeboina" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/pdf" title="Résumé" href="/Sai_Krishna_Vaddeboina_Resume.pdf" />

    <!-- Schema.org Person markup for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body class="min-h-screen antialiased">
    <slot />

    <script is:inline>
      // Cursor spotlight
      document.querySelectorAll(".spotlight").forEach((el) => {
        el.addEventListener("mousemove", (e) => {
          const rect = el.getBoundingClientRect();
          el.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
          el.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
        });
      });

      // Reveal on scroll
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
